{
  "$schema": "https://unpkg.com/oh-my-opencode-slim@latest/oh-my-opencode-slim.schema.json",
  "preset": "omniroute",
  "presets": {
    "omniroute": {
      "orchestrator": {
        "model": "omniroute/omos/orchestrator",
        "mcps": ["*"]
      },
      "oracle": {
        "model": "omniroute/omos/oracle",
        "mcps": ["*"]
      },
      "librarian": {
        "model": "omniroute/omos/librarian",
        "mcps": ["context7", "exa", "gh_grep"]
      },
      "explorer": {
        "model": "omniroute/omos/explorer",
        "mcps": []
      },
      "designer": {
        "model": "omniroute/omos/designer",
        "mcps": []
      },
      "fixer": {
        "model": "omniroute/omos/fixer",
        "mcps": []
      },
      "observer": {
        "model": "omniroute/omos/observer",
        "mcps": []
      },
      "council": {
        "model": "omniroute/omos/council",
        "mcps": ["*"]
      }
    },
    "openai": {
      "orchestrator": {
        "model": "openai/gpt-5.6-terra",
        "variant": "medium",
        "mcps": ["*"]
      },
      "oracle": {
        "model": "openai/gpt-5.6-sol",
        "variant": "high",
        "mcps": ["*"]
      },
      "librarian": {
        "model": "openai/gpt-5.6-luna",
        "variant": "low",
        "mcps": ["context7", "exa", "gh_grep"]
      },
      "explorer": {
        "model": "openai/gpt-5.6-luna",
        "variant": "low",
        "mcps": []
      },
      "designer": {
        "model": "openai/gpt-5.6-luna",
        "variant": "medium",
        "mcps": []
      },
      "fixer": {
        "model": "openai/gpt-5.6-luna",
        "variant": "medium",
        "mcps": []
      }
    },
    "opencode-go": {
      "orchestrator": {
        "model": "omniroute/opencode-go/glm-5.2",
        "mcps": ["*"]
      },
      "oracle": {
        "model": "omniroute/opencode-go/glm-5.2",
        "variant": "max",
        "mcps": ["*"]
      },
      "council": {
        "model": "omniroute/opencode-go/deepseek-v4-pro",
        "variant": "high",
        "mcps": ["*"]
      },
      "librarian": {
        "model": "omniroute/opencode-go/minimax-m3",
        "mcps": ["context7", "exa", "gh_grep"]
      },
      "explorer": {
        "model": "omniroute/opencode-go/deepseek-v4-pro",
        "variant": "max",
        "mcps": []
      },
      "designer": {
        "model": "omniroute/opencode-go/kimi-k2.7-code",
        "mcps": []
      },
      "fixer": {
        "model": "omniroute/opencode-go/glm-5.2",
        "mcps": []
      },
      "observer": {
        "model": "omniroute/opencode-go/kimi-k2.6",
        "mcps": []
      }
    }
  },
  "council": {
    "timeout": 1200000,
    "presets": {
      "default": {
        "alpha": {
	  "model": "omniroute/omos/councillor-alpha"
	},
	"beta": {
          "model": "omniroute/omos/councillor-beta"
        },
        "gamma": {
          "model": "omniroute/omos/councillor-gamma"
        },
        "delta": {
          "model": "omniroute/omos/councillor-delta"
        }
      }
    }
  },
  "companion": {
    "enabled": false
  },
  "multiplexer": {
    "type": "auto",
    "layout": "main-vertical",
    "main_pane_size": 50
  },
  "disabled_mcps": [
    "websearch"
  ]
}
