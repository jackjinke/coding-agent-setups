{
  "$schema": "https://unpkg.com/oh-my-opencode-slim@latest/oh-my-opencode-slim.schema.json",
  "preset": "omniroute",
  "presets": {
    "omniroute": {
      "orchestrator": {
        "model": "omniroute/combo/coding-alpha",
        "variant": "high",
        "mcps": ["*"]
      },
      "oracle": {
        "model": "omniroute/combo/reviewer",
        "variant": "high",
        "mcps": ["*"]
      },
      "librarian": {
        "model": "omniroute/combo/coding-beta",
        "variant": "high",
        "mcps": ["context7", "exa", "gh_grep"]
      },
      "explorer": {
        "model": "omniroute/combo/coding-beta",
        "variant": "high",
        "mcps": []
      },
      "designer": {
        "model": "omniroute/combo/designer",
        "variant": "xhigh",
        "mcps": []
      },
      "fixer": {
        "model": "omniroute/combo/coding-beta",
        "variant": "xhigh",
        "mcps": []
      },
      "observer": {
        "model": "omniroute/combo/coding-beta",
        "variant": "high",
        "mcps": []
      },
      "council": {
        "model": "omniroute/combo/coding-beta",
        "variant": "xhigh",
        "mcps": ["*"]
      }
    }
  },
  "council": {
    "timeout": 1200000,
    "presets": {
      "default": {
        "reviewer": {
          "model": "omniroute/combo/reviewer",
          "variant": "high"
        },
        "coding-alpha": {
          "model": "omniroute/combo/coding-alpha",
          "variant": "xhigh"
        }
      }
    }
  },
  "companion": {
    "enabled": false
  },
  "multiplexer": {
    "type": "auto",
    "layout": "main-vertical",
    "main_pane_size": 50
  },
  "disabled_mcps": [
    "websearch"
  ]
}
