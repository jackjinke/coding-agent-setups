{
  "$schema": "https://unpkg.com/oh-my-opencode-slim@latest/oh-my-opencode-slim.schema.json",
  "preset": "omniroute",
  "presets": {
    "omniroute": {
      "orchestrator": {
        "model": "omniroute/omos/orchestrator"
      },
      "oracle": {
        "model": "omniroute/omos/oracle"
      },
      "librarian": {
        "model": "omniroute/omos/librarian"
      },
      "explorer": {
        "model": "omniroute/omos/explorer"
      },
      "designer": {
        "model": "omniroute/omos/designer"
      },
      "fixer": {
        "model": "omniroute/omos/fixer"
      },
      "observer": {
        "model": "omniroute/omos/observer"
      },
      "council": {
        "model": "omniroute/omos/council-lead"
      }
    },
    "openai": {
      "orchestrator": {
        "model": "openai/gpt-5.6-terra",
        "variant": "medium"
      },
      "oracle": {
        "model": "openai/gpt-5.6-sol",
        "variant": "high"
      },
      "librarian": {
        "model": "openai/gpt-5.6-luna",
        "variant": "low"
      },
      "explorer": {
        "model": "openai/gpt-5.6-luna",
        "variant": "low"
      },
      "designer": {
        "model": "openai/gpt-5.6-luna",
        "variant": "medium"
      },
      "fixer": {
        "model": "openai/gpt-5.6-luna",
        "variant": "medium"
      }
    },
    "opencode-go": {
      "orchestrator": {
        "model": "omniroute/opencode-go/glm-5.2"
      },
      "oracle": {
        "model": "omniroute/opencode-go/glm-5.2",
        "variant": "max"
      },
      "council": {
        "model": "omniroute/opencode-go/deepseek-v4-pro",
        "variant": "high"
      },
      "librarian": {
        "model": "omniroute/opencode-go/minimax-m3"
      },
      "explorer": {
        "model": "omniroute/opencode-go/deepseek-v4-pro",
        "variant": "max"
      },
      "designer": {
        "model": "omniroute/opencode-go/kimi-k2.7-code"
      },
      "fixer": {
        "model": "omniroute/opencode-go/glm-5.2"
      },
      "observer": {
        "model": "omniroute/opencode-go/kimi-k2.6"
      }
    }
  },
  "council": {
    "timeout": 900000,
    "presets": {
      "default": {
        "alpha": {
	  "model": "omniroute/omos/council-alpha"
	},
	"beta": {
          "model": "omniroute/omos/council-beta"
        },
        "gamma": {
          "model": "omniroute/omos/council-gamma"
        }
      }
    }
  },
  "companion": {
    "enabled": false
  },
  "multiplexer": {
    "type": "auto"
  },
  "disabled_mcps": []
}
