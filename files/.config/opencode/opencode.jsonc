{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "omniroute": {
      "options": {
        "baseURL": "{env:OPENCODE_OMNIROUTE_BASE_URL}",
        "refreshOnList": true,
        "apiMode": "responses"
      }
    }
  },
  "plugin": [
    "opencode-omniroute-auth",
    "@tarquinen/opencode-dcp",
    "./plugins/caveman/plugin.js",
    "opencode-pty",
    "oh-my-opencode-slim"
  ],
  "tools": {
    "webfetch": false,
    "websearch": false
  },
  "mcp": {
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true,
      "headers": {
        "x-api-key": "{env:EXA_API_KEY}"
      }
    }
  },
  "permission": {
    "external_directory": {
      "*": "ask",
      "/tmp": "allow",
      "/tmp/**": "allow",
      "/var/**": "allow"
    }
  },
  "agent": {
    "build": {
      "permission": {
        "task": "deny"
      }
    },
    "plan": {
      "permission": {
        "task": {
          "*": "deny",
          "explorer": "allow",
          "librarian": "allow"
        }
      }
    },
    "general": {
      "disable": true
    },
    "explore": {
      "disable": true
    }
  },
  "lsp": true,
  "share": "disabled"
}
