#!/usr/bin/env bash
set -euo pipefail

session_base="$(basename "$PWD")"

next_session_name() {
  local index=1
  local name

  while :; do
    name="${session_base}-${index}"
    if ! tmux has-session -t "=${name}" 2>/dev/null; then
      printf '%s\n' "$name"
      return
    fi
    ((index++))
  done
}

if [[ -z "${TMUX:-}" || "${OMO_TMUX_MANAGED:-}" != "1" ]]; then
  if ! command -v tmux >/dev/null 2>&1; then
    printf 'omo must start in tmux, but tmux was not found on PATH.\n' >&2
    exit 127
  fi

  session_name="$(next_session_name)"
  session_target="=${session_name}"

  if [[ -n "${TMUX:-}" ]]; then
    tmux new-session -d -s "$session_name" -n "$session_name" -c "$PWD" -- env OMO_TMUX_MANAGED=1 "$0" "$@"
    exec tmux switch-client -t "$session_target"
  fi

  exec tmux new-session -s "$session_name" -n "$session_name" -c "$PWD" -- env OMO_TMUX_MANAGED=1 "$0" "$@"
fi

unset OMO_TMUX_MANAGED

for arg in "$@"; do
  case "$arg" in
    --port|--port=*)
      printf 'omo chooses a random high port; pass other opencode arguments only.\n' >&2
      exit 2
      ;;
  esac
done

env_file="${OPENCODE_ENV_FILE:-$HOME/.config/opencode/.env}"
if [[ -f "$env_file" ]]; then
  set -a
  # shellcheck disable=SC1090
  source "$env_file"
  set +a
fi

if command -v shuf >/dev/null 2>&1; then
  port="$(shuf -i 49152-65535 -n 1)"
else
  port="$((49152 + (((RANDOM << 15) | RANDOM) % 16384)))"
fi

export OPENCODE_PORT="$port"
exec opencode --port "$port" "$@"
