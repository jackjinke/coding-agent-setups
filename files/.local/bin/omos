#!/usr/bin/env bash
set -euo pipefail

real_opencode="$HOME/.opencode/bin/opencode"
env_file="${OPENCODE_ENV_FILE:-$HOME/.config/opencode/.env}"

load_env() {
  if [[ -f "$env_file" ]]; then
    set -a
    source "$env_file"
    set +a
  fi
}

random_port() {
  if command -v shuf >/dev/null 2>&1; then
    shuf -i 49152-65535 -n 1
  else
    printf '%d\n' "$((49152 + (((RANDOM << 15) | RANDOM) % 16384)))"
  fi
}

if (($#)); then
  load_env
  exec "$real_opencode" "$@"
fi

if [[ -n "${HERDR_ENV:-}" ]]; then
  load_env
  port="$(random_port)"
  export OPENCODE_PORT="$port"
  exec "$real_opencode" --port "$port"
fi

command -v herdr >/dev/null 2>&1 || {
  printf 'omos requires herdr when launched outside Herdr.\n' >&2
  exit 127
}

session_base="$(basename "$PWD")"
create_json="$(herdr workspace create --cwd "$PWD" --label "$session_base" --focus)"
if command -v jq >/dev/null 2>&1; then
  root_pane="$(printf '%s' "$create_json" | jq -r '.result.root_pane.pane_id // empty')"
else
  root_pane="$(printf '%s' "$create_json" | sed -n 's/.*"root_pane":{[^}]*"pane_id":"\([^"]*\)".*/\1/p')"
fi

if [[ -z "$root_pane" ]]; then
  printf 'omos could not determine the new Herdr workspace pane.\n' >&2
  exit 1
fi

launch_cmd="exec env HERDR_ENV=1 $(printf '%q' "$0")"
herdr pane run "$root_pane" "$launch_cmd"
exec herdr
