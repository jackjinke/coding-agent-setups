-    # macOS / Linux fallback
-    for cmd in [["open", "-a", "Google Chrome"], ["google-chrome"], ["chromium-browser"]]:
+    # macOS / Linux fallback - order by platform so the right command is tried first
+    import sys
+    if sys.platform == "darwin":
+        cmds = [["open", "-a", "Google Chrome"]]
+    else:
+        cmds = [["google-chrome"], ["chromium-browser"]]
+    for cmd in cmds:
         try:
             subprocess.Popen(cmd)
             return
